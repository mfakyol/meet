# =========================================================================
# HOST nginx (on the Linux server, NOT in a container).
# Terminates TLS for meet.fatihakyol.com and reverse-proxies to the client
# container published on 127.0.0.1:8087. WebRTC needs HTTPS (getUserMedia),
# and Socket.io needs the WebSocket upgrade passed through.
#
#   sudo certbot --nginx -d meet.fatihakyol.com
# =========================================================================

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    listen [::]:80;
    server_name meet.fatihakyol.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name meet.fatihakyol.com;

    ssl_certificate     /etc/letsencrypt/live/meet.fatihakyol.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/meet.fatihakyol.com/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:8087;
        proxy_http_version 1.1;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        $connection_upgrade;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout  3600s;
        proxy_send_timeout  3600s;
    }
}
