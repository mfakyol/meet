# Server configuration (safe placeholders — copy to .env and adjust)

# Port the signaling server listens on.
PORT=5001

# Max participants per room. Mesh is O(n²); this is a DoS/UX guardrail.
MAX_PER_ROOM=8

# Allowed client origin(s) for CORS + Socket.io. Comma-separated.
# REQUIRED in production (the server refuses to default to "*").
# e.g. CLIENT_URL=https://meet.example.com
CLIENT_URL=http://localhost:5173

# Number of proxy hops to trust (behind nginx). 0 = trust none.
TRUST_PROXY=0

# NODE_ENV=production
